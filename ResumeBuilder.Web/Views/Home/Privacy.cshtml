@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="row justify-content-center mt-4 mb-5 text-white">
    <div class="col-lg-10 col-xl-9">
        <div class="card border-0 bg-dark text-white rounded-4 shadow-lg p-5">
            <!-- Header Section -->
            <div class="text-center mb-5">
                <div class="d-inline-flex align-items-center justify-content-center bg-primary bg-opacity-10 text-primary rounded-circle mb-3" style="width: 80px; height: 80px;">
                    <i class="bi bi-shield-lock-fill fs-1"></i>
                </div>
                <h1 class="fw-bold display-5 luxury-heading text-white mb-2">Privacy Policy</h1>
                <p class="text-secondary small font-monospace">Last Updated: June 12, 2026</p>
                <div class="w-25 mx-auto border-bottom border-primary border-2 mt-3" style="opacity: 0.3;"></div>
            </div>

            <!-- Intro -->
            <p class="lead text-secondary mb-5 text-center px-md-4">
                At <strong>ResumeBuilder</strong>, we value your privacy and are committed to protecting the personal information you share with us. This Privacy Policy explains what information we collect, why we collect it, and how we use it to provide a better experience.
            </p>

            <!-- Grid Sections to fill space beautifully -->
            <div class="row g-4 mb-5">
                <!-- Section 1: Information We Collect -->
                <div class="col-md-6">
                    <div class="bg-black bg-opacity-20 border border-secondary border-opacity-25 rounded-4 p-4 h-100">
                        <h5 class="fw-bold text-primary font-monospace mb-3">
                            <i class="bi bi-database-fill-down me-2"></i>Information We Collect
                        </h5>
                        <p class="text-secondary small">When you create an account or use our platform, we may collect information such as:</p>
                        <ul class="list-unstyled text-secondary small ps-0">
                            <li class="mb-2"><i class="bi bi-check2 text-primary me-2"></i>Your name and email address</li>
                            <li class="mb-2"><i class="bi bi-check2 text-primary me-2"></i>Login credentials</li>
                            <li class="mb-2"><i class="bi bi-check2 text-primary me-2"></i>Resume details and documents you choose to create or upload</li>
                            <li class="mb-2"><i class="bi bi-check2 text-primary me-2"></i>Basic usage information that helps us improve our services</li>
                        </ul>
                        <p class="text-muted small mb-0 mt-3 italic"><i class="bi bi-info-circle me-1"></i>We only collect the information necessary to provide our features effectively.</p>
                    </div>
                </div>

                <!-- Section 2: How We Use Your Information -->
                <div class="col-md-6">
                    <div class="bg-black bg-opacity-20 border border-secondary border-opacity-25 rounded-4 p-4 h-100">
                        <h5 class="fw-bold text-primary font-monospace mb-3">
                            <i class="bi bi-gear-wide-connected me-2"></i>How We Use Your Information
                        </h5>
                        <p class="text-secondary small">The information you provide helps us to:</p>
                        <ul class="list-unstyled text-secondary small ps-0">
                            <li class="mb-2"><i class="bi bi-arrow-right-short text-primary me-1"></i>Create and manage your account</li>
                            <li class="mb-2"><i class="bi bi-arrow-right-short text-primary me-1"></i>Save and organize your resumes</li>
                            <li class="mb-2"><i class="bi bi-arrow-right-short text-primary me-1"></i>Allow you to edit, download, and manage your documents</li>
                            <li class="mb-2"><i class="bi bi-arrow-right-short text-primary me-1"></i>Improve the performance and functionality of our platform</li>
                            <li class="mb-2"><i class="bi bi-arrow-right-short text-primary me-1"></i>Respond to your questions or support requests</li>
                        </ul>
                        <p class="text-muted small mb-0 mt-3"><i class="bi bi-heart-fill text-danger me-1"></i>We do not sell or rent your personal information to anyone.</p>
                    </div>
                </div>

                <!-- Section 3: Keeping Your Information Safe -->
                <div class="col-md-6">
                    <div class="bg-black bg-opacity-20 border border-secondary border-opacity-25 rounded-4 p-4 h-100">
                        <h5 class="fw-bold text-primary font-monospace mb-3">
                            <i class="bi bi-shield-fill-check me-2"></i>Keeping Your Information Safe
                        </h5>
                        <p class="text-secondary small">
                            We take reasonable measures to keep your information secure and protect it from unauthorized access or misuse. While no online platform can guarantee complete security, we continuously work to maintain a safe environment for our users.
                        </p>
                    </div>
                </div>

                <!-- Section 4: Your Control Over Your Data -->
                <div class="col-md-6">
                    <div class="bg-black bg-opacity-20 border border-secondary border-opacity-25 rounded-4 p-4 h-100">
                        <h5 class="fw-bold text-primary font-monospace mb-3">
                            <i class="bi bi-sliders me-2"></i>Your Control Over Your Data
                        </h5>
                        <p class="text-secondary small">
                            Your resume belongs to you. You can update, edit, or remove your personal information and resume content whenever you choose. If you decide to stop using ResumeBuilder, you may request the deletion of your account and associated data.
                        </p>
                    </div>
                </div>

                <!-- Section 5: Cookies & Analytics (Added Detail) -->
                <div class="col-md-6">
                    <div class="bg-black bg-opacity-20 border border-secondary border-opacity-25 rounded-4 p-4 h-100">
                        <h5 class="fw-bold text-primary font-monospace mb-3">
                            <i class="bi bi-cookie me-2"></i>Cookies & Session State
                        </h5>
                        <p class="text-secondary small">
                            We use essential cookies and session state identifiers to keep you signed in as you navigate between pages. We do not use persistent tracking cookies, adware, or target advertising scripts on our platform.
                        </p>
                    </div>
                </div>

                <!-- Section 6: Third-Party Services -->
                <div class="col-md-6">
                    <div class="bg-black bg-opacity-20 border border-secondary border-opacity-25 rounded-4 p-4 h-100">
                        <h5 class="fw-bold text-primary font-monospace mb-3">
                            <i class="bi bi-google me-2"></i>Third-Party Services
                        </h5>
                        <p class="text-secondary small">
                            If you choose to sign in using services such as Google, only the information required for authentication will be accessed. Your use of these services is also subject to their respective privacy policies.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Footer Notes -->
            <div class="border-top border-secondary border-opacity-25 pt-4 text-center">
                <h6 class="fw-bold font-monospace text-primary mb-2">Updates to This Policy</h6>
                <p class="text-secondary small mb-4 max-w-600 mx-auto">
                    As our platform continues to improve, this Privacy Policy may be updated from time to time. Any changes will be reflected on this page, and the latest version will always be available here.
                </p>
                <div class="d-inline-block bg-black bg-opacity-30 border border-secondary border-opacity-30 rounded-pill px-4 py-3">
                    <span class="text-white-50 small font-monospace"><i class="bi bi-envelope-fill text-primary me-2"></i>Need Help? Contact Us:</span>
                    <a href="mailto:support@resumebuilder.com" class="text-primary fw-bold ms-2 text-decoration-none hover-white">support@resumebuilder.com</a>
                </div>
            </div>
        </div>
    </div>
</div>
