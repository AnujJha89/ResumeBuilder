@{
    ViewData["Title"] = "Authorization Failed";
}

<style>
    .auth-error-card {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: 24px;
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        overflow: hidden;
        box-shadow: 0 12px 40px rgba(0, 0, 0, 0.05);
    }
    .auth-graphic-container {
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        min-height: 320px;
    }
    .auth-graphic-circle {
        width: 280px;
        height: 280px;
        border-radius: 50%;
        background-color: var(--brand-hover);
        position: relative;
        overflow: hidden;
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.15);
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .auth-doc-mockup {
        width: 220px;
        height: 140px;
        background: #ffffff;
        border-radius: 8px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
        display: flex;
        position: relative;
        overflow: hidden;
        transform: rotate(-4deg);
        border: 1px solid #e2e8f0;
    }
    .auth-doc-sidebar {
        width: 35%;
        background: var(--brand-primary);
        height: 100%;
        padding: 12px 8px;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }
    .auth-doc-main {
        width: 65%;
        height: 100%;
        padding: 12px;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }
    .auth-doc-avatar {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.25);
    }
    .auth-doc-line-sm {
        height: 4px;
        border-radius: 2px;
        background: rgba(255, 255, 255, 0.3);
    }
    .auth-doc-line-primary {
        height: 8px;
        border-radius: 4px;
        background: var(--brand-primary);
        width: 70%;
    }
    .auth-doc-line-dark {
        height: 5px;
        border-radius: 2px;
        background: #64748b;
    }
    .auth-doc-line-muted {
        height: 4px;
        border-radius: 2px;
        background: #cbd5e1;
    }
    .auth-lock-badge {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        background: #0f172a; /* Slate 900 */
        border: 2px solid #ffffff;
        box-shadow: 0 6px 16px rgba(0, 0, 0, 0.25);
        display: flex;
        align-items: center;
        justify-content: center;
        position: absolute;
        top: 22%;
        right: 16%;
        color: #ffffff;
        z-index: 10;
        font-size: 1.25rem;
    }
</style>

<div class="row justify-content-center align-items-center min-vh-75 py-5">
    <div class="col-lg-10 col-xl-9">
        <div class="card auth-error-card p-4 p-md-5">
            <div class="row align-items-center g-4">
                <!-- Left Details Column -->
                <div class="col-md-7 order-2 order-md-1">
                    <h1 class="display-2 fw-bold text-primary mb-1" style="font-family: var(--font-mono) !important; letter-spacing: -2px;">401</h1>
                    <h2 class="fw-bold luxury-heading mb-3 fs-2 text-primary">Authorization Failed.</h2>
                    <p class="text-secondary mb-4 fs-6 leading-relaxed">
                        The page has been inactive for a while, or your session has expired. You need to log in again to access this resource. If you recently logged out or changed your credentials, please sign in with your updated details.
                    </p>
                    <div class="d-flex gap-3 flex-wrap">
                        <a asp-controller="Account" asp-action="Login" class="btn btn-primary px-5 py-2.5 rounded-3 fw-semibold hover-lift">
                            Login
                        </a>
                        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-light px-4 py-2.5 rounded-3 fw-semibold hover-lift">
                            Go Home
                        </a>
                    </div>
                </div>

                <!-- Right Graphic Column -->
                <div class="col-md-5 order-1 order-md-2 auth-graphic-container">
                    <div class="auth-graphic-circle">
                        <!-- Lock Badge Floating -->
                        <div class="auth-lock-badge">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                                <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                            </svg>
                        </div>
                        <!-- Resume Document Mockup -->
                        <div class="auth-doc-mockup">
                            <div class="auth-doc-sidebar">
                                <div class="auth-doc-avatar"></div>
                                <div class="auth-doc-line-sm" style="width: 80%;"></div>
                                <div class="auth-doc-line-sm" style="width: 50%;"></div>
                                <div class="auth-doc-line-sm" style="width: 65%;"></div>
                            </div>
                            <div class="auth-doc-main">
                                <div class="auth-doc-line-primary"></div>
                                <div class="auth-doc-line-dark" style="width: 90%;"></div>
                                <div class="auth-doc-line-muted" style="width: 100%;"></div>
                                <div class="auth-doc-line-muted" style="width: 80%;"></div>
                                <div class="auth-doc-line-muted" style="width: 95%;"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
