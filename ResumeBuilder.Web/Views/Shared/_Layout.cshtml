@using Microsoft.AspNetCore.Identity
@using ResumeBuilder.Core.Entities
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ResumeBuilder.Web</title>
    <script type="importmap"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
    <script>
        (function () {
            const theme = localStorage.getItem('theme') || 'light';
            document.documentElement.setAttribute('data-bs-theme', theme);
        })();
    </script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ResumeBuilder.Web.styles.css" asp-append-version="true" />
    
    <style>
        /* CSS variables or classes to handle the adaptive color splitting seamlessly */
        .logo-resume {
            color: #000000; /* Crisp Black in Light Mode */
        }
        [data-bs-theme="dark"] .logo-resume {
            color: #ffffff; /* Crisp White in Dark Mode */
        }
        
        .settings-nav-btn {
            font-size: 1.25rem;
            transition: color 0.2s ease;
            cursor: pointer;
            line-height: 1;
            padding: 0;
            display: inline-flex;
            align-items: center;
        }
        
        /* Default state: light shade of white in dark mode, dark sky-blue in light mode */
        [data-bs-theme="dark"] .settings-nav-btn {
            color: rgba(255, 255, 255, 0.85) !important;
        }
        [data-bs-theme="dark"] .settings-nav-btn:hover {
            color: #ffffff !important;
        }
        [data-bs-theme="light"] .settings-nav-btn {
            color: rgba(2, 132, 199, 0.6) !important;
        }
        [data-bs-theme="light"] .settings-nav-btn:hover {
            color: #0284c7 !important;
        }
        
        /* Active / Clicked state is grey */
        .settings-nav-btn.active {
            color: #6b7280 !important;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm border-bottom bg-body-tertiary border-body">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold luxury-heading text-decoration-none text-primary" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="logo-resume">Resume</span>Builder
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-body-secondary" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        @if (SignInManager.IsSignedIn(User))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-body-secondary" asp-area="" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                            </li>
                        }
                    </ul>
                    <ul class="navbar-nav">
                        @if (SignInManager.IsSignedIn(User))
                        {
                            var user = await UserManager.GetUserAsync(User);
                            var name = user?.FullName ?? User.Identity?.Name ?? "User";
                            <li class="nav-item d-flex align-items-center">
                                <span class="nav-link text-body-secondary me-2 small">Hello, @name!</span>
                            </li>
                            <li class="nav-item d-flex align-items-center ms-3">
                                <a asp-controller="Dashboard" asp-action="Settings" class="settings-nav-btn @(ViewContext.RouteData.Values["action"]?.ToString() == "Settings" ? "active" : "")" aria-label="Settings" title="Settings">
                                    <i class="bi bi-gear-fill"></i>
                                </a>
                            </li>
                            <form asp-controller="Account" asp-action="Logout" method="post" id="globalLogoutForm" class="d-none">
                                @Html.AntiForgeryToken()
                            </form>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-body-secondary" asp-controller="Account" asp-action="Register">Sign Up</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-body-secondary" asp-controller="Account" asp-action="Login">Sign In</a>
                            </li>
                        }
                        <li class="nav-item d-flex align-items-center ms-3">
                            <button id="themeToggleBtn" class="btn btn-link nav-link p-0 text-body-secondary d-flex align-items-center" aria-label="Toggle Theme" style="font-size: 1.25rem; border: none; background: none; box-shadow: none;">
                                <i id="themeToggleIcon" class="bi bi-moon-fill"></i>
                            </button>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container-xxl px-4 px-md-5">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - ResumeBuilder.Web - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/proximity.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script>
        async function globalSignOut(event) {
            if (event) event.preventDefault();
            
            try {
                localStorage.clear();
                sessionStorage.clear();
            } catch (e) {
                console.error('Failed to clear storage:', e);
            }
            
            document.cookie.split(";").forEach(function(c) {
                document.cookie = c.replace(/^ +/, "").replace(/=.*/, "=;expires=" + new Date().toUTCString() + ";path=/");
            });

            document.body.style.transition = 'opacity 0.3s ease';
            document.body.style.opacity = '0';
            
            setTimeout(() => {
                const form = document.getElementById('globalLogoutForm');
                if (form) {
                    form.submit();
                } else {
                    window.location.href = '/';
                }
            }, 300);
        }

        document.addEventListener('DOMContentLoaded', () => {
            const btn = document.getElementById('themeToggleBtn');
            const icon = document.getElementById('themeToggleIcon');
            
            function updateIcon(theme) {
                if (theme === 'dark') {
                    icon.className = 'bi bi-sun-fill';
                } else {
                    icon.className = 'bi bi-moon-fill';
                }
            }
            
            const currentTheme = document.documentElement.getAttribute('data-bs-theme') || 'light';
            updateIcon(currentTheme);
            
            if (btn) {
                btn.addEventListener('click', () => {
                    const oldTheme = document.documentElement.getAttribute('data-bs-theme') || 'light';
                    const newTheme = oldTheme === 'dark' ? 'light' : 'dark';
                    document.documentElement.setAttribute('data-bs-theme', newTheme);
                    localStorage.setItem('theme', newTheme);
                    updateIcon(newTheme);
                    window.dispatchEvent(new Event('themeChanged'));
                });
            }
        });
    </script>
</body>
</html>