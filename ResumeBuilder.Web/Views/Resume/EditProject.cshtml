@model ResumeBuilder.Web.ViewModels.ProjectViewModel
@{
    ViewBag.ResumeId = Model.ResumeId;
    ViewBag.ActiveTab = "projects";
    ViewData["Title"] = $"Edit Project - {ViewBag.ResumeTitle}";
}

<div class="row min-vh-75 mt-4 text-white">
    <div class="col-md-3 mb-4">
        <!-- Editor Sidebar -->
        <partial name="_WizardSidebar" />
    </div>

    <div class="col-md-9">
        <div class="card border-0 bg-dark text-white rounded-4 shadow-sm p-5">
            <!-- Progress Tracker -->
            <partial name="_WizardProgress" />

            <div class="mb-4">
                <h3 class="fw-bold tracking-tight">Edit Project</h3>
                <p class="text-secondary">Modify the title, duration, technologies used, or description details of the selected project.</p>
            </div>

            <form asp-controller="Resume" asp-action="EditProject" asp-route-id="@Model.Id" method="post" novalidate>
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="ResumeId" />
                <input type="hidden" asp-for="DisplayOrder" />

                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="form-floating text-dark">
                            <input asp-for="ProjectTitle" class="form-control bg-transparent text-white border-secondary rounded-3" placeholder="Title" />
                            <label asp-for="ProjectTitle" class="text-secondary">Project Title (e.g. Chat Application)</label>
                            <span asp-validation-for="ProjectTitle" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating text-dark">
                            <input asp-for="Duration" class="form-control bg-transparent text-white border-secondary rounded-3" placeholder="Duration" />
                            <label asp-for="Duration" class="text-secondary">Duration (e.g. Jan 2026 - Mar 2026)</label>
                            <span asp-validation-for="Duration" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating text-dark">
                            <input asp-for="TechnologiesUsed" class="form-control bg-transparent text-white border-secondary rounded-3" placeholder="Technologies" />
                            <label asp-for="TechnologiesUsed" class="text-secondary">Technologies Used (e.g. React, ASP.NET Core)</label>
                            <span asp-validation-for="TechnologiesUsed" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating text-dark">
                            <input asp-for="GitHubLink" class="form-control bg-transparent text-white border-secondary rounded-3" placeholder="GitHub URL" />
                            <label asp-for="GitHubLink" class="text-secondary">GitHub Repository Link (Optional)</label>
                            <span asp-validation-for="GitHubLink" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="col-12">
                        <div class="form-floating text-dark">
                            <textarea asp-for="Description" class="form-control bg-transparent text-white border-secondary rounded-3" placeholder="Description" style="height: 150px;"></textarea>
                            <label asp-for="Description" class="text-secondary">Brief description of project details and key accomplishments...</label>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-3 mt-4 border-top border-secondary border-opacity-25 pt-4">
                    <a asp-controller="Resume" asp-action="Projects" asp-route-resumeId="@Model.ResumeId" class="btn btn-outline-light px-4 py-2.5 rounded-3 font-monospace">
                        Cancel
                    </a>
                    <button type="submit" class="btn btn-primary px-4 py-2.5 rounded-3 fw-semibold font-monospace hover-lift">
                        Save Changes 
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
