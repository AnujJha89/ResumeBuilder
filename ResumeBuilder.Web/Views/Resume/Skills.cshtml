@model IEnumerable<ResumeBuilder.Core.Entities.Skill>
@{
    var resumeId = (int)ViewBag.ResumeId;
    ViewData["Title"] = $"Skills - {ViewBag.ResumeTitle}";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show border-0 rounded-4 shadow-sm bg-success text-white font-monospace mb-4 animate__animated animate__fadeIn" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row min-vh-75 mt-4 text-white">
    <div class="col-md-3 mb-4">
        <!-- Editor Sidebar -->
        <partial name="_WizardSidebar" />
    </div>

    <div class="col-md-9">
        <div class="card border-0 bg-dark text-white rounded-4 shadow-sm p-5">
            <!-- Progress Tracker -->
            <partial name="_WizardProgress" />

            <div class="mb-4">
                <h3 class="fw-bold tracking-tight">Technical Skills</h3>
                <p class="text-secondary">Tag your technical competencies, tools, programming languages, and framework proficiencies.</p>
            </div>

            <!-- Existing Entries Grouped by Category -->
            <div class="mb-5">
                <h5 class="fw-bold text-primary font-monospace mb-3"> Categorized Skills Tags</h5>
                @if (Model == null || !Model.Any())
                {
                    <div class="bg-black bg-opacity-20 border border-secondary border-opacity-25 rounded-4 p-4 text-center">
                        <i class="bi bi-info-circle text-secondary display-6 mb-2 d-block"></i>
                        <p class="text-secondary mb-0">No technical skills added yet. Tag them below using the input form.</p>
                    </div>
                }
                else
                {
                    var categories = new[] { "Languages", "Frameworks", "Databases", "Tools" };
                    <div class="d-flex flex-column gap-4">
                        @foreach (var category in categories)
                        {
                            var categorySkills = Model.Where(s => s.SkillCategory == category).ToList();
                            if (categorySkills.Any())
                            {
                                <div class="bg-black bg-opacity-20 border border-secondary border-opacity-25 rounded-4 p-4">
                                    <h6 class="fw-bold text-white-50 font-monospace mb-3 border-bottom border-secondary border-opacity-20 pb-2">@category</h6>
                                    <div class="d-flex flex-wrap gap-2">
                                        @foreach (var skill in categorySkills)
                                        {
                                            <div class="skill-badge animate__animated animate__fadeIn font-monospace">
                                                <span>@skill.SkillName</span>
                                                @if (!string.IsNullOrEmpty(skill.Proficiency))
                                                {
                                                    <span class="text-primary fw-bold" style="font-size: 0.75rem;">(@skill.Proficiency)</span>
                                                }
                                                <a asp-action="EditSkill" asp-route-id="@skill.Id" class="text-white-50 text-decoration-none hover-white" title="Edit skill">
                                                    <i class="bi bi-pencil-fill" style="font-size: 0.75rem;"></i>
                                                </a>
                                                <form asp-action="DeleteSkill" asp-route-id="@skill.Id" method="post" onsubmit="return confirm('Remove skill?');" class="d-inline p-0 m-0">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="badge-delete bg-transparent border-0 p-0 m-0 align-middle">
                                                        <i class="bi bi-x-circle-fill"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        }
                    </div>
                }
            </div>

            <!-- Insertion Form -->
            <div class="border-top border-secondary border-opacity-25 pt-4">
                <h5 class="fw-bold text-primary font-monospace mb-4"> Add Skill Tag</h5>
                <form asp-action="AddSkill" method="post" novalidate>
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ResumeId" value="@resumeId" />

                    <div class="row g-3">
                        <div class="col-md-5">
                            <div class="form-floating text-dark">
                                <input name="SkillName" class="form-control bg-transparent text-white border-secondary rounded-3" placeholder="Skill Name" required />
                                <label class="text-secondary">Skill Name (e.g. C, ASP.NET Core, Git)</label>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-floating text-dark">
                                <select name="SkillCategory" class="form-select bg-transparent text-white border-secondary rounded-3" required>
                                    <option value="Languages">Languages</option>
                                    <option value="Frameworks">Frameworks</option>
                                    <option value="Databases">Databases</option>
                                    <option value="Tools">Tools</option>
                                </select>
                                <label class="text-secondary">Category Group</label>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-floating text-dark">
                                <select name="Proficiency" class="form-select bg-transparent text-white border-secondary rounded-3">
                                    <option value="">No proficiency</option>
                                    <option value="Beginner">Beginner</option>
                                    <option value="Intermediate">Intermediate</option>
                                    <option value="Advanced">Advanced</option>
                                    <option value="Expert">Expert</option>
                                </select>
                                <label class="text-secondary">Proficiency Level</label>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end mt-4">
                        <button type="submit" class="btn btn-outline-primary px-4 font-monospace hover-lift">
                            Add Tag 
                        </button>
                    </div>
                </form>
            </div>

            <!-- Wizard Actions -->
            <div class="d-flex justify-content-between align-items-center border-top border-secondary border-opacity-25 pt-4 mt-5">
                <a asp-action="Educations" asp-route-resumeId="@resumeId" class="btn btn-outline-light px-4 py-2.5 rounded-3 font-monospace">
                    <i class="bi bi-arrow-left me-1"></i> Back
                </a>
                <a asp-action="Projects" asp-route-resumeId="@resumeId" class="btn btn-primary px-5 py-2.5 rounded-3 fw-semibold font-monospace hover-lift">
                    Save & Continue <i class="bi bi-arrow-right ms-1"></i>
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
