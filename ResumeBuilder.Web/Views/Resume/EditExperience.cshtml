@model ResumeBuilder.Web.ViewModels.ExperienceViewModel
@{
    ViewBag.ResumeId = Model.ResumeId;
    ViewBag.ActiveTab = "experience";
    ViewData["Title"] = $"Edit Experience - {ViewBag.ResumeTitle}";
}

<div class="row min-vh-75 mt-4 text-white">
    <div class="col-md-3 mb-4">
        <!-- Editor Sidebar -->
        <partial name="_WizardSidebar" />
    </div>

    <div class="col-md-9">
        <div class="card border-0 bg-dark text-white rounded-4 shadow-sm p-5">
            <!-- Progress Tracker -->
            <partial name="_WizardProgress" />

            <div class="mb-4">
                <h3 class="fw-bold tracking-tight">Edit Work Experience</h3>
                <p class="text-secondary">Modify the company name, position role, dates, or responsibilities description details below.</p>
            </div>

            <form asp-controller="Resume" asp-action="EditExperience" asp-route-id="@Model.Id" method="post" novalidate>
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="ResumeId" />
                <input type="hidden" asp-for="DisplayOrder" />

                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="form-floating text-dark">
                            <input asp-for="CompanyName" class="form-control bg-transparent text-white border-secondary rounded-3" placeholder="Company" />
                            <label asp-for="CompanyName" class="text-secondary">Company Name (e.g. Google)</label>
                            <span asp-validation-for="CompanyName" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating text-dark">
                            <input asp-for="Position" class="form-control bg-transparent text-white border-secondary rounded-3" placeholder="Position" />
                            <label asp-for="Position" class="text-secondary">Position / Role (e.g. Software Dev Intern)</label>
                            <span asp-validation-for="Position" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-floating text-dark">
                            <input asp-for="StartDate" type="date" class="form-control bg-transparent text-white border-secondary rounded-3" placeholder="Start" />
                            <label asp-for="StartDate" class="text-secondary">Start Date</label>
                            <span asp-validation-for="StartDate" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-floating text-dark @(Model.IsCurrent ? "opacity-40" : "")" id="endDateContainer">
                            <input asp-for="EndDate" type="date" class="form-control bg-transparent text-white border-secondary rounded-3" placeholder="End" disabled="@(Model.IsCurrent ? "disabled" : null)" />
                            <label asp-for="EndDate" class="text-secondary">End Date</label>
                            <span asp-validation-for="EndDate" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="col-md-4 d-flex align-items-center">
                        <div class="form-check font-monospace ms-3">
                            <input asp-for="IsCurrent" type="checkbox" class="form-check-input bg-dark border-secondary" id="isCurrentCheckbox" />
                            <label class="form-check-label text-white-50" for="isCurrentCheckbox">I currently work here</label>
                        </div>
                    </div>
                    <div class="col-12">
                        <div class="form-floating text-dark">
                            <textarea asp-for="Responsibilities" class="form-control bg-transparent text-white border-secondary rounded-3" placeholder="Responsibilities" style="height: 180px;"></textarea>
                            <label asp-for="Responsibilities" class="text-secondary">Responsibilities & accomplishments description...</label>
                            <span asp-validation-for="Responsibilities" class="text-danger small"></span>
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-3 mt-4 border-top border-secondary border-opacity-25 pt-4">
                    <a asp-controller="Resume" asp-action="Experiences" asp-route-resumeId="@Model.ResumeId" class="btn btn-outline-light px-4 py-2.5 rounded-3 font-monospace">
                        Cancel
                    </a>
                    <button type="submit" class="btn btn-primary px-4 py-2.5 rounded-3 fw-semibold font-monospace hover-lift">
                        Save Changes 
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const isCurrentCheckbox = document.getElementById('isCurrentCheckbox');
        const endDateContainer = document.getElementById('endDateContainer');
        const endDateInput = endDateContainer.querySelector('input');

        isCurrentCheckbox.addEventListener('change', function() {
            if (this.checked) {
                endDateInput.disabled = true;
                endDateInput.value = '';
                endDateContainer.classList.add('opacity-40');
            } else {
                endDateInput.disabled = false;
                endDateContainer.classList.remove('opacity-40');
            }
        });
    </script>
}
