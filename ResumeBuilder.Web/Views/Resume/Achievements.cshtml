@model IEnumerable<ResumeBuilder.Core.Entities.Achievement>
@{
    var resumeId = (int)ViewBag.ResumeId;
    ViewData["Title"] = $"Achievements - {ViewBag.ResumeTitle}";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show border-0 rounded-4 shadow-sm bg-success text-white font-monospace mb-4 animate__animated animate__fadeIn" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row min-vh-75 mt-4 text-white">
    <div class="col-md-3 mb-4">
        <!-- Editor Sidebar -->
        <partial name="_WizardSidebar" />
    </div>

    <div class="col-md-9">
        <div class="card border-0 bg-dark text-white rounded-4 shadow-sm p-5">
            <!-- Progress Tracker -->
            <partial name="_WizardProgress" />

            <div class="mb-4">
                <h3 class="fw-bold tracking-tight">Achievements & Honors</h3>
                <p class="text-secondary">Register competitions, hackathons, open source contributions, or academic honors achieved.</p>
            </div>

            <!-- Existing Achievements -->
            <div class="mb-5">
                <h5 class="fw-bold text-primary font-monospace mb-3"> Current Achievements</h5>
                @if (Model == null || !Model.Any())
                {
                    <div class="bg-black bg-opacity-20 border border-secondary border-opacity-25 rounded-4 p-4 text-center">
                        <i class="bi bi-info-circle text-secondary display-6 mb-2 d-block"></i>
                        <p class="text-secondary mb-0">No achievements added yet. Use the form below to register your honors.</p>
                    </div>
                }
                else
                {
                    <div class="bg-black bg-opacity-20 border border-secondary border-opacity-25 rounded-4 overflow-hidden">
                        <div class="row notion-list-header px-4 pt-3 fw-bold small font-monospace">
                            <div class="col-md-4">Honor / Title</div>
                            <div class="col-md-2">Category</div>
                            <div class="col-md-4">Details Description</div>
                            <div class="col-md-2 text-end">Actions</div>
                        </div>
                        @foreach (var ach in Model)
                        {
                            <div class="row notion-row align-items-center px-4 font-monospace">
                                <div class="col-md-4">
                                    <span class="fw-bold text-white"> @ach.Title</span>
                                </div>
                                <div class="col-md-2">
                                    <span class="badge bg-secondary bg-opacity-35 text-white font-monospace">@ach.Category</span>
                                </div>
                                <div class="col-md-4 text-white-50 small">@ach.Description</div>
                                <div class="col-md-2 text-end d-flex justify-content-end gap-3">
                                    <a asp-action="EditAchievement" asp-route-id="@ach.Id" class="action-icon text-decoration-none" title="Edit achievement">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <form asp-action="DeleteAchievement" asp-route-id="@ach.Id" method="post" onsubmit="return confirm('Delete this achievement?');" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="action-icon text-danger border-0 bg-transparent p-0" title="Delete achievement">
                                            <i class="bi bi-trash3-fill"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            <!-- Insertion Form -->
            <div class="border-top border-secondary border-opacity-25 pt-4">
                <h5 class="fw-bold text-primary font-monospace mb-4"> Add Achievement Entry</h5>
                <form asp-action="AddAchievement" method="post" novalidate>
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ResumeId" value="@resumeId" />

                    <div class="row g-3">
                        <div class="col-md-8">
                            <div class="form-floating text-dark">
                                <input name="Title" class="form-control bg-transparent text-white border-secondary rounded-3" placeholder="Title" required />
                                <label class="text-secondary">Achievement Title (e.g. 1st Rank in Hackathon)</label>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-floating text-dark">
                                <select name="Category" class="form-select bg-transparent text-white border-secondary rounded-3" required>
                                    <option value="Awards">Awards</option>
                                    <option value="Hackathons">Hackathons</option>
                                    <option value="Scholarships">Scholarships</option>
                                    <option value="Competitions">Competitions</option>
                                </select>
                                <label class="text-secondary">Category</label>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="form-floating text-dark">
                                <textarea name="Description" class="form-control bg-transparent text-white border-secondary rounded-3" placeholder="Description" style="height: 100px;"></textarea>
                                <label class="text-secondary">Description details (optional information about your achievement)...</label>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end mt-4">
                        <button type="submit" class="btn btn-outline-primary px-4 font-monospace hover-lift">
                            Add Achievement 
                        </button>
                    </div>
                </form>
            </div>

            <!-- Wizard Actions -->
            <div class="d-flex justify-content-between align-items-center border-top border-secondary border-opacity-25 pt-4 mt-5">
                <a asp-action="Certifications" asp-route-resumeId="@resumeId" class="btn btn-outline-light px-4 py-2.5 rounded-3 font-monospace">
                    <i class="bi bi-arrow-left me-1"></i> Back
                </a>
                <a asp-action="Preview" asp-route-resumeId="@resumeId" class="btn btn-primary px-5 py-2.5 rounded-3 fw-semibold font-monospace hover-lift">
                    Save & Continue <i class="bi bi-arrow-right ms-1"></i>
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
