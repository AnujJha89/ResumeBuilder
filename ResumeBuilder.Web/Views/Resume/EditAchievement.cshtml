@model ResumeBuilder.Web.ViewModels.AchievementViewModel
@{
    ViewBag.ResumeId = Model.ResumeId;
    ViewBag.ActiveTab = "achievements";
    ViewData["Title"] = $"Edit Achievement - {ViewBag.ResumeTitle}";
}

<div class="row min-vh-75 mt-4 text-white">
    <div class="col-md-3 mb-4">
        <!-- Editor Sidebar -->
        <partial name="_WizardSidebar" />
    </div>

    <div class="col-md-9">
        <div class="card border-0 bg-dark text-white rounded-4 shadow-sm p-5">
            <!-- Progress Tracker -->
            <partial name="_WizardProgress" />

            <div class="mb-4">
                <h3 class="fw-bold tracking-tight">Edit Achievement Details</h3>
                <p class="text-secondary">Modify the title or description details of the selected achievement below.</p>
            </div>

            <form asp-controller="Resume" asp-action="EditAchievement" asp-route-id="@Model.Id" method="post" novalidate>
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="ResumeId" />
                <input type="hidden" asp-for="DisplayOrder" />

                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <div class="row g-3">
                    <div class="col-md-8">
                        <div class="form-floating text-dark">
                            <input asp-for="Title" class="form-control bg-transparent text-white border-secondary rounded-3" placeholder="Title" />
                            <label asp-for="Title" class="text-secondary">Achievement Title (e.g. 1st Rank in Hackathon)</label>
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-floating text-dark">
                            <select asp-for="Category" class="form-select bg-transparent text-white border-secondary rounded-3">
                                <option value="Awards">Awards</option>
                                <option value="Hackathons">Hackathons</option>
                                <option value="Scholarships">Scholarships</option>
                                <option value="Competitions">Competitions</option>
                            </select>
                            <label asp-for="Category" class="text-secondary">Category Group</label>
                            <span asp-validation-for="Category" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="col-12">
                        <div class="form-floating text-dark">
                            <textarea asp-for="Description" class="form-control bg-transparent text-white border-secondary rounded-3" placeholder="Description" style="height: 120px;"></textarea>
                            <label asp-for="Description" class="text-secondary">Description details (optional details)...</label>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-3 mt-4 border-top border-secondary border-opacity-25 pt-4">
                    <a asp-controller="Resume" asp-action="Achievements" asp-route-resumeId="@Model.ResumeId" class="btn btn-outline-light px-4 py-2.5 rounded-3 font-monospace">
                        Cancel
                    </a>
                    <button type="submit" class="btn btn-primary px-4 py-2.5 rounded-3 fw-semibold font-monospace hover-lift">
                        Save Changes 
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
