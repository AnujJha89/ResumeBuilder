@model ResumeBuilder.Web.ViewModels.EducationViewModel
@{
    ViewBag.ResumeId = Model.ResumeId;
    ViewBag.ActiveTab = "education";
    ViewData["Title"] = $"Edit Education - {ViewBag.ResumeTitle}";
}

<div class="row min-vh-75 mt-4 text-white">
    <div class="col-md-3 mb-4">
        <!-- Editor Sidebar -->
        <partial name="_WizardSidebar" />
    </div>

    <div class="col-md-9">
        <div class="card border-0 bg-dark text-white rounded-4 shadow-sm p-5">
            <!-- Progress Tracker -->
            <partial name="_WizardProgress" />

            <div class="mb-4">
                <h3 class="fw-bold tracking-tight">Edit Academic Record</h3>
                <p class="text-secondary">Modify your degree title, school name, grades, or graduation date details below.</p>
            </div>

            <form asp-controller="Resume" asp-action="EditEducation" asp-route-id="@Model.Id" method="post" novalidate>
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="ResumeId" />
                <input type="hidden" asp-for="DisplayOrder" />

                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="form-floating text-dark">
                            <select asp-for="Degree" class="form-select bg-transparent text-white border-secondary rounded-3">
                                <option value="Graduation">Graduation</option>
                                <option value="Intermediate">Intermediate</option>
                                <option value="Matriculation">Matriculation</option>
                            </select>
                            <label asp-for="Degree" class="text-secondary">Degree / School Level</label>
                            <span asp-validation-for="Degree" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating text-dark">
                            <input asp-for="InstitutionName" class="form-control bg-transparent text-white border-secondary rounded-3" placeholder="Institution Name" />
                            <label asp-for="InstitutionName" class="text-secondary">Institution (School or College Name)</label>
                            <span asp-validation-for="InstitutionName" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating text-dark">
                            <input asp-for="BoardOrUniversity" class="form-control bg-transparent text-white border-secondary rounded-3" placeholder="Board or University" />
                            <label asp-for="BoardOrUniversity" class="text-secondary">Board or University (e.g. CBSE, DTU)</label>
                            <span asp-validation-for="BoardOrUniversity" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-floating text-dark">
                            <input asp-for="PassingYear" class="form-control bg-transparent text-white border-secondary rounded-3" placeholder="Passing Year" />
                            <label asp-for="PassingYear" class="text-secondary">Passing Year</label>
                            <span asp-validation-for="PassingYear" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-floating text-dark">
                            <input asp-for="PercentageOrCGPA" class="form-control bg-transparent text-white border-secondary rounded-3" placeholder="Percentage or CGPA" />
                            <label asp-for="PercentageOrCGPA" class="text-secondary">CGPA or Percentage (e.g. 9.4, 91%)</label>
                            <span asp-validation-for="PercentageOrCGPA" class="text-danger small"></span>
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-3 mt-4 border-top border-secondary border-opacity-25 pt-4">
                    <a asp-controller="Resume" asp-action="Educations" asp-route-resumeId="@Model.ResumeId" class="btn btn-outline-light px-4 py-2.5 rounded-3 font-monospace">
                        Cancel
                    </a>
                    <button type="submit" class="btn btn-primary px-4 py-2.5 rounded-3 fw-semibold font-monospace hover-lift">
                        Save Changes 
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
